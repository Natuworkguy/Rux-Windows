    pub const SERVICE_QUERY_STATUS:          uint32 = 0x0004u32;
    pub const SERVICE_ENUMERATE_DEPENDENTS:  uint32 = 0x0008u32;
    pub const SERVICE_START:                 uint32 = 0x0010u32;
    pub const SERVICE_STOP:                  uint32 = 0x0020u32;
    pub const SERVICE_PAUSE_CONTINUE:        uint32 = 0x0040u32;
    pub const SERVICE_INTERROGATE:           uint32 = 0x0080u32;
    pub const SERVICE_USER_DEFINED_CONTROL:  uint32 = 0x0100u32;
    pub const SERVICE_ALL_ACCESS:            uint32 = 0x000F01FFu32;


    // Constants — Service Types


    pub const SERVICE_KERNEL_DRIVER:       uint32 = 0x00000001u32;
    pub const SERVICE_FILE_SYSTEM_DRIVER:  uint32 = 0x00000002u32;
    pub const SERVICE_WIN32_OWN_PROCESS:   uint32 = 0x00000010u32;
    pub const SERVICE_WIN32_SHARE_PROCESS: uint32 = 0x00000020u32;
    pub const SERVICE_INTERACTIVE_PROCESS: uint32 = 0x00000100u32;


