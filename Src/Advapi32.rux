    pub const SERVICE_SYSTEM_START: uint32 = 0x00000001u32;
    pub const SERVICE_AUTO_START:   uint32 = 0x00000002u32;
    pub const SERVICE_DEMAND_START: uint32 = 0x00000003u32;
    pub const SERVICE_DISABLED:     uint32 = 0x00000004u32;


    // Constants — Service States


    pub const SERVICE_STOPPED:          uint32 = 0x00000001u32;
    pub const SERVICE_START_PENDING:    uint32 = 0x00000002u32;
    pub const SERVICE_STOP_PENDING:     uint32 = 0x00000003u32;
    pub const SERVICE_RUNNING:          uint32 = 0x00000004u32;
    pub const SERVICE_CONTINUE_PENDING: uint32 = 0x00000005u32;
    pub const SERVICE_PAUSE_PENDING:    uint32 = 0x00000006u32;
    pub const SERVICE_PAUSED:           uint32 = 0x00000007u32;


    // Constants — Service Control Codes


    pub const SERVICE_CONTROL_STOP:       uint32 = 0x00000001u32;
    pub const SERVICE_CONTROL_PAUSE:      uint32 = 0x00000002u32;
    pub const SERVICE_CONTROL_CONTINUE:   uint32 = 0x00000003u32;
    pub const SERVICE_CONTROL_INTERROGATE: uint32 = 0x00000004u32;
    pub const SERVICE_CONTROL_SHUTDOWN:   uint32 = 0x00000005u32;


    // Constants — Service Info Levels


    pub const SERVICE_CONFIG_DESCRIPTION:              uint32 = 1u32;
