    pub const SERVICE_CONFIG_DELAYED_AUTO_START_INFO:  uint32 = 3u32;
    pub const SERVICE_CONFIG_FAILURE_ACTIONS_FLAG:     uint32 = 4u32;
    pub const SERVICE_CONFIG_SERVICE_SID_INFO:         uint32 = 5u32;
    pub const SERVICE_CONFIG_REQUIRED_PRIVILEGES_INFO: uint32 = 6u32;
    pub const SERVICE_CONFIG_PREFERRED_NODE:           uint32 = 9u32;


