        func GetComputerNameA(buf: *char8, size: *uint32) -> bool32;
        /// Replaces environment-variable strings with the values defined for the current user
        /// https://learn.microsoft.com/en-us/windows/win32/api/processenv/nf-processenv-expandenvironmentstringsa
        func ExpandEnvironmentStringsA(src: *const char8, dst: *char8, size: uint32) -> uint32;
        /// Retrieves the contents of the specified variable from the environment block of the calling process
