        func TlsAlloc() -> uint32;
        /// Stores a value in the calling thread's thread local storage slot
        /// https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-tlssetvalue
        func TlsSetValue(tlsIndex: uint32, tlsValue: *opaque) -> bool32;
