        /// https://learn.microsoft.com/en-us/windows/win32/api/fileapi/nf-fileapi-gettemppatha
        func GetTempPathA(bufLen: uint32, buf: *char8) -> uint32;
        /// Retrieves the NetBIOS name of the local computer
