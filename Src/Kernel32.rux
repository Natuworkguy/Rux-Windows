        func GetSystemDirectoryA(buffer: *char8, size: uint32) -> uint32;
        /// Retrieves the path of the Windows directory
        /// https://learn.microsoft.com/en-us/windows/win32/api/sysinfoapi/nf-sysinfoapi-getwindowsdirectorya
        func GetWindowsDirectoryA(buffer: *char8, size: uint32) -> uint32;
        
        // Debugging
        /// Sends a string to the debugger for display
