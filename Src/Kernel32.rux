    // Structures — Process, Memory, Thread


    pub struct MemoryBasicInformation {
        pub baseAddress:       *opaque;
        pub allocationBase:    *opaque;
        pub allocationProtect: uint32;
        pub partitionId:       uint16;
        pub _pad1:             uint16;
        pub regionSize:        uint;
        pub state:             uint32;
        pub protect:           uint32;
        pub type_:             uint32;
        pub _pad2:             uint32;
    }

    pub struct ProcessEntry32 {
        pub dwSize:              uint32;
        pub cntUsage:            uint32;
        pub th32ProcessID:       uint32;
        pub th32DefaultHeapID:   uint;
        pub th32ModuleID:        uint32;
        pub cntThreads:          uint32;
        pub th32ParentProcessID: uint32;
        pub pcPriClassBase:      int32;
        pub dwFlags:             uint32;
        pub szExeFile:           char8[260];
    }

    pub struct ModuleEntry32 {
        pub dwSize:         uint32;
        pub th32ModuleID:   uint32;
        pub th32ProcessID:  uint32;
        pub glblcntUsage:   uint32;
        pub proccntUsage:   uint32;
        pub modBaseAddr:    *opaque;
        pub modBaseSize:    uint32;
        pub hModule:        *opaque;
        pub szModule:       char8[256];
        pub szExePath:      char8[260];
    }

    pub struct CriticalSection {
        pub _opaque0: uint64;
        pub _opaque1: uint64;
        pub _opaque2: uint64;
        pub _opaque3: uint64;
        pub _opaque4: uint64;
    }

    pub struct Overlapped {
        pub internal:     uint;
        pub internalHigh: uint;
        pub offset:       uint32;
        pub offsetHigh:   uint32;
        pub hEvent:       *opaque;
    }

    pub struct SystemTime {
        pub year:         uint16;
        pub month:        uint16;
        pub dayOfWeek:    uint16;
        pub day:          uint16;
        pub hour:         uint16;
        pub minute:       uint16;
        pub second:       uint16;
        pub milliseconds: uint16;
    }

    pub struct SystemInfo {
        pub processorArchitecture: uint16;
        pub _reserved:             uint16;
        pub pageSize:              uint32;
        pub minimumApplicationAddress: *opaque;
        pub maximumApplicationAddress: *opaque;
        pub activeProcessorMask:   *opaque;
        pub numberOfProcessors:    uint32;
        pub processorType:         uint32;
        pub allocationGranularity: uint32;
        pub processorLevel:        uint16;
        pub processorRevision:     uint16;
    }

    pub struct MemoryStatusEx {
        pub length:                uint32;
        pub _pad1:                 uint32;
        pub memoryLoad:            uint32;
        pub _pad2:                 uint32;
        pub totalPhys:             uint64;
        pub availPhys:             uint64;
        pub totalPageFile:         uint64;
        pub availPageFile:         uint64;
        pub totalVirtual:          uint64;
        pub availVirtual:          uint64;
        pub availExtendedVirtual:  uint64;
    }


