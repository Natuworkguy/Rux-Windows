    // Extern — kernel32.dll (Core Functions)


    @[Import(lib: "kernel32.dll")]
    extern {
        // Console
        /// Allocates a new console for the calling process
        /// https://learn.microsoft.com/en-us/windows/console/allocconsole
        func AllocConsole() -> bool32;
        /// Generates simple tones on the speaker
        /// https://learn.microsoft.com/en-us/windows/win32/api/utilapiset/nf-utilapiset-beep
        func Beep(freq: uint32, duration: uint32) -> bool32;
        /// Ends the calling process and all its threads
        /// https://learn.microsoft.com/en-us/windows/win32/api/processthreadsapi/nf-processthreadsapi-exitprocess
        func ExitProcess(exitCode: uint32);
        
        // Error handling
        func GetLastError() -> uint32;
        func SetLastError(error: uint32);
        
        // Heap management
        /// Retrieves a handle to the default heap of the calling process
        /// https://learn.microsoft.com/en-us/windows/win32/api/heapapi/nf-heapapi-getprocessheap
        func GetProcessHeap() -> *opaque;
        /// Allocates a block of memory from a heap. The allocated memory is not movable
        /// https://learn.microsoft.com/en-us/windows/win32/api/heapapi/nf-heapapi-heapalloc
        func HeapAlloc(heap: *opaque, flags: uint32, bytes: uint) -> *opaque;
        /// Frees a memory block allocated from a heap by the HeapAlloc or HeapReAlloc function
        /// https://learn.microsoft.com/en-us/windows/win32/api/heapapi/nf-heapapi-heapfree
        func HeapFree(heap: *opaque, flags: uint32, mem: *opaque) -> bool32;
        /// Reallocates a block of memory from a heap
        /// https://learn.microsoft.com/en-us/windows/win32/api/heapapi/nf-heapapi-heaprealloc
        func HeapReAlloc(heap: *opaque, flags: uint32, mem: *opaque, bytes: uint) -> *opaque;
        
        // String conversion
        /// Maps a character string to a UTF-16 wide character string
        /// https://learn.microsoft.com/en-us/windows/win32/api/stringapiset/nf-stringapiset-multibytetowidechar
        func MultiByteToWideChar(
            codePage: uint32,
            flags: uint32,
            multiByteStr: *const char8,
            multiByte: int32,
            wideCharStr: *char16,
            wideChar: int32) -> int32;
        
        // Memory utilities (RTL functions)
        /// Compares two blocks of memory and returns the number of bytes that match until the first difference
        /// https://learn.microsoft.com/en-us/windows-hardware/drivers/ddi/wdm/nf-wdm-rtlcomparememory
        func RtlCompareMemory(source1: *const opaque, source2: *const opaque, length: uint) -> uint;
        /// Copies a block of memory from one location to another
        /// https://learn.microsoft.com/en-us/previous-versions/windows/desktop/legacy/aa366535(v=vs.85)
        func RtlCopyMemory(destination: *opaque, source: *const opaque, length: uint);
        /// Fills a block of memory with the specified fill value
        /// https://learn.microsoft.com/en-us/windows-hardware/drivers/ddi/wdm/nf-wdm-rtlfillmemory
        func RtlFillMemory(destination: *opaque, length: uint, fill: int32);
        /// Fills a block of memory with zeros, given a pointer to the block and the length in bytes
        /// https://learn.microsoft.com/en-us/windows-hardware/drivers/ddi/wdm/nf-wdm-rtlzeromemory
        func RtlZeroMemory(destination: *opaque, length: uint);
        
        // Timing
        /// Suspends the execution of the current thread until the time-out interval elapses
        /// https://learn.microsoft.com/en-us/windows/win32/api/synchapi/nf-synchapi-sleep
        func Sleep(milliseconds: uint32);
        func GetTickCount() -> uint32;
        func GetTickCount64() -> uint64;
        func QueryPerformanceCounter(counterOut: *uint64) -> bool32;
        func QueryPerformanceFrequency(freqOut: *uint64) -> bool32;
        func GetSystemTimeAsFileTime(time: *uint64);
        
        // File I/O
        func ReadFile(
            file: *opaque,
            buffer: *opaque,
            numberOfBytesToRead: uint32,
            numberOfBytesRead: *uint32,
            overlapped: *opaque) -> bool32;
        
        func WriteFile(
            file: *opaque,
            buffer: *const opaque,
            bytesToWrite: uint32,
            bytesWritten: *uint32,
            overlapped: *opaque) -> bool32;
        
        // Console output
        func WriteConsoleA(
            consoleOutput: *opaque,
            buffer: *const char8,
            numberOfCharsToWrite: uint32,
            numberOfCharsWritten: *uint32,
            reserved: *opaque) -> bool32;
        
        func WriteConsoleW(
            consoleOutput: *opaque,
            buffer: *const char16,
            numberOfCharsToWrite: uint32,
            numberOfCharsWritten: *uint32,
            reserved: *opaque) -> bool32;
        
        // Interlocked operations for thread safety
        func InterlockedExchangePointer(target: *opaque, value: *opaque) -> *opaque;
        func InterlockedCompareExchangePointer(target: *opaque, exchange: *opaque, comparand: *opaque) -> *opaque;
        func InterlockedExchange(target: *int32, value: int32) -> int32;
        func InterlockedCompareExchange(target: *int32, exchange: int32, comparand: int32) -> int32;
        
        // WOW64 detection
        func IsWow64Process(hProcess: *opaque, wow64Process: *bool32) -> bool32;
    }


    // Extern — kernel32.dll (Process, Memory, DLL, Thread, Sync)


    @[Import(lib: "kernel32.dll")]
    extern {
        // Process management
        func OpenProcess(desiredAccess: uint32, inheritHandle: bool32, processId: uint32) -> *opaque;
        func CloseHandle(handle: *opaque) -> bool32;
        func TerminateProcess(hProcess: *opaque, exitCode: uint32) -> bool32;
        func GetCurrentProcess() -> *opaque;
        func GetCurrentProcessId() -> uint32;
        func GetExitCodeProcess(hProcess: *opaque, exitCode: *uint32) -> bool32;
        func QueryFullProcessImageNameA(hProcess: *opaque, flags: uint32, name: *char8, size: *uint32) -> bool32;
        
        // Process memory
        func ReadProcessMemory(hProcess: *opaque, baseAddress: *const opaque, buffer: *opaque, size: uint, bytesRead: *uint) -> bool32;
        func WriteProcessMemory(hProcess: *opaque, baseAddress: *opaque, buffer: *const opaque, size: uint, bytesWritten: *uint) -> bool32;
        
        // Virtual memory (remote)
        func VirtualAllocEx(hProcess: *opaque, address: *opaque, size: uint, allocationType: uint32, protect: uint32) -> *opaque;
        func VirtualFreeEx(hProcess: *opaque, address: *opaque, size: uint, freeType: uint32) -> bool32;
        func VirtualProtectEx(hProcess: *opaque, address: *opaque, size: uint, newProtect: uint32, oldProtect: *uint32) -> bool32;
        func VirtualQueryEx(hProcess: *opaque, address: *const opaque, buffer: *opaque, length: uint) -> uint;
        
        // Virtual memory (local)
        func VirtualAlloc(address: *opaque, size: uint, allocationType: uint32, protect: uint32) -> *opaque;
        func VirtualFree(address: *opaque, size: uint, freeType: uint32) -> bool32;
        func VirtualProtect(address: *opaque, size: uint, newProtect: uint32, oldProtect: *uint32) -> bool32;
        func VirtualQuery(address: *const opaque, buffer: *opaque, length: uint) -> uint;
        
        // Remote threads
        func CreateRemoteThread(hProcess: *opaque, threadAttr: *opaque, stackSize: uint, startAddress: *const opaque, parameter: *opaque, creationFlags: uint32, threadId: *uint32) -> *opaque;
        
        // Synchronization
        func WaitForSingleObject(hHandle: *opaque, milliseconds: uint32) -> uint32;
        func WaitForMultipleObjects(count: uint32, handles: *opaque, waitAll: bool32, milliseconds: uint32) -> uint32;
        
        // DLL management
        func LoadLibraryA(libFileName: *const char8) -> *opaque;
        func LoadLibraryW(libFileName: *const char16) -> *opaque;
        func LoadLibraryExA(libFileName: *const char8, file: *opaque, flags: uint32) -> *opaque;
        func GetModuleHandleA(moduleName: *const char8) -> *opaque;
        func GetModuleHandleW(moduleName: *const char16) -> *opaque;
        func GetProcAddress(hModule: *opaque, procName: *const char8) -> *const opaque;
        func FreeLibrary(hModule: *opaque) -> bool32;
        func GetModuleFileNameA(hModule: *opaque, filename: *char8, size: uint32) -> uint32;
        func DisableThreadLibraryCalls(hModule: *opaque) -> bool32;
        func SetDllDirectoryA(pathName: *const char8) -> bool32;
        func GetModuleHandleExA(flags: uint32, name: *const char8, hModule: *opaque) -> bool32;
        
        // Toolhelp32 snapshot (process/module enumeration)
        func CreateToolhelp32Snapshot(flags: uint32, processId: uint32) -> *opaque;
        func Process32First(hSnapshot: *opaque, entry: *ProcessEntry32) -> bool32;
        func Process32Next(hSnapshot: *opaque, entry: *ProcessEntry32) -> bool32;
        func Module32First(hSnapshot: *opaque, entry: *ModuleEntry32) -> bool32;
        func Module32Next(hSnapshot: *opaque, entry: *ModuleEntry32) -> bool32;
        
        // Thread management
        func CreateThread(threadAttr: *opaque, stackSize: uint, startAddress: *const opaque, parameter: *opaque, flags: uint32, threadId: *uint32) -> *opaque;
        func OpenThread(desiredAccess: uint32, inheritHandle: bool32, threadId: uint32) -> *opaque;
        func GetCurrentThread() -> *opaque;
        func GetCurrentThreadId() -> uint32;
        func ExitThread(exitCode: uint32);
        func TerminateThread(hThread: *opaque, exitCode: uint32) -> bool32;
        func GetExitCodeThread(hThread: *opaque, exitCode: *uint32) -> bool32;
        
        // Thread control
        func SuspendThread(hThread: *opaque) -> uint32;
        func ResumeThread(hThread: *opaque) -> uint32;
        func SetThreadPriority(hThread: *opaque, priority: int32) -> bool32;
        func GetThreadPriority(hThread: *opaque) -> int32;
        func SwitchToThread() -> bool32;
        
        // Event objects
        func CreateEventA(eventAttr: *opaque, manualReset: bool32, initialState: bool32, name: *const char8) -> *opaque;
        func SetEvent(hEvent: *opaque) -> bool32;
        func ResetEvent(hEvent: *opaque) -> bool32;
        
        // Mutex objects
        func CreateMutexA(mutexAttr: *opaque, initialOwner: bool32, name: *const char8) -> *opaque;
        func ReleaseMutex(hMutex: *opaque) -> bool32;
        
        // Critical sections
        func InitializeCriticalSection(cs: *opaque);
        func EnterCriticalSection(cs: *opaque);
        func LeaveCriticalSection(cs: *opaque);
        func DeleteCriticalSection(cs: *opaque);
        
        // Thread Local Storage
        func TlsAlloc() -> uint32;
        func TlsSetValue(tlsIndex: uint32, tlsValue: *opaque) -> bool32;
        func TlsGetValue(tlsIndex: uint32) -> *opaque;
        func TlsFree(tlsIndex: uint32) -> bool32;
        
        // System directories
        func GetSystemDirectoryA(buffer: *char8, size: uint32) -> uint32;
        func GetWindowsDirectoryA(buffer: *char8, size: uint32) -> uint32;
        
        // Debugging
        func OutputDebugStringA(outputString: *const char8);
        
        // Cache control
        func FlushInstructionCache(hProcess: *opaque, baseAddress: *const opaque, size: uint) -> bool32;
        
        // Error formatting
        func FormatMessageA(
            flags: uint32,
            source: *opaque,
            messageId: uint32,
            langId: uint32,
            buffer: *char8,
            size: uint32,
            args: *opaque
        ) -> uint32;
        
        // Environment / System info
        func GetTempPathA(bufLen: uint32, buf: *char8) -> uint32;
        func GetComputerNameA(buf: *char8, size: *uint32) -> bool32;
        func ExpandEnvironmentStringsA(src: *const char8, dst: *char8, size: uint32) -> uint32;
        func GetEnvironmentVariableA(name: *const char8, buf: *char8, size: uint32) -> uint32;
        func SetEnvironmentVariableA(name: *const char8, value: *const char8) -> bool32;
        
        // Locale / Code page
        func GetUserDefaultLCID() -> uint32;
        func GetACP() -> uint32;
        
        // File operations
        func CreateFileA(
            fileName: *const char8,
            desiredAccess: uint32,
            shareMode: uint32,
            securityAttr: *opaque,
            creationDisposition: uint32,
            flagsAndAttributes: uint32,
            templateFile: *opaque
        ) -> *opaque;
        
        func GetFileSizeEx(file: *opaque, size: *uint64) -> bool32;
        func SetFilePointerEx(
            file: *opaque,
            distance: int64,
            newPtr: *int64,
            moveMethod: uint32
        ) -> bool32;
        
        func GetFileAttributesA(fileName: *const char8) -> uint32;
        func SetFileAttributesA(fileName: *const char8, attrs: uint32) -> bool32;
        func GetFileType(hFile: *opaque) -> uint32;
        
        func CopyFileA(existing: *const char8, newFile: *const char8, failIfExists: bool32) -> bool32;
        func MoveFileA(existing: *const char8, newFile: *const char8) -> bool32;
        func DeleteFileA(fileName: *const char8) -> bool32;
        
        // Directory operations
        func CreateDirectoryA(path: *const char8, securityAttr: *opaque) -> bool32;
        func RemoveDirectoryA(path: *const char8) -> bool32;
        func GetCurrentDirectoryA(bufLen: uint32, buf: *char8) -> uint32;
        func SetCurrentDirectoryA(path: *const char8) -> bool32;
        func GetLogicalDrives() -> uint32;
        func GetDriveTypeA(rootPath: *const char8) -> uint32;
        func GetDiskFreeSpaceExA(
            dir: *const char8,
            freeBytesAvail: *uint64,
            totalBytes: *uint64,
            totalFree: *uint64
        ) -> bool32;
        
        // System information
        func GetSystemInfo(info: *opaque);
        func GetNativeSystemInfo(info: *opaque);
        func GlobalMemoryStatusEx(buffer: *opaque) -> bool32;
        func GetLogicalProcessorInformation(buffer: *opaque, retLen: *uint32) -> bool32;
        
        // Time functions
        func GetSystemTime(time: *opaque);
        func SetSystemTime(time: *opaque) -> bool32;
        func GetLocalTime(time: *opaque);
        func SetLocalTime(time: *opaque) -> bool32;
        func FileTimeToLocalFileTime(inFileTime: *uint64, outLocal: *uint64) -> bool32;
        func FileTimeToSystemTime(inFileTime: *uint64, systemTime: *opaque) -> bool32;
        func SystemTimeToFileTime(systemTime: *opaque, fileTime: *uint64) -> bool32;
        func CompareFileTime(time1: *uint64, time2: *uint64) -> int32;
        
        // Console control
        func SetConsoleTitleA(title: *const char8) -> bool32;
        func GetConsoleTitleA(buf: *char8, size: uint32) -> uint32;
        func GetConsoleMode(console: *opaque, mode: *uint32) -> bool32;
        func SetConsoleMode(console: *opaque, mode: uint32) -> bool32;
        func SetConsoleTextAttribute(console: *opaque, attrs: uint16) -> bool32;
    }

}